# --- Database ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/resume_enhancer

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- LLM Providers ---
# Default provider when the client does not specify one: "mistral" or "openai"
DEFAULT_LLM_PROVIDER=mistral

MISTRAL_API_KEY=
# Optional: extra Mistral keys for rotation (comma-separated). Combined with MISTRAL_API_KEY.
MISTRAL_API_KEYS=
MISTRAL_MODEL=mistral-large-latest

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# --- App ---
CORS_ORIGINS=http://localhost:5173
MAX_UPLOAD_MB=10
UPLOAD_DIR=./storage/uploads

# --- Screening integrations ---
# Optional GitHub token (raises API rate limit 60 -> 5000/hr for repo/profile checks)
GITHUB_TOKEN=
ENABLE_LINK_CHECKS=true
PLAGIARISM_THRESHOLD=0.95

# --- Email (SMTP) for sharing reports with candidates ---
# Gmail example: host smtp.gmail.com, port 587, user = your gmail, password = an App Password
# (Google account > Security > 2-Step Verification > App passwords). Do NOT use your normal password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
APP_PUBLIC_URL=http://localhost:5173

# Default admin (created on first startup if it does not exist)
ADMIN_EMAIL=admin@nxtwave.local
ADMIN_PASSWORD=ChangeMe123!
